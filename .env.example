# Outbound webhook (n8n) that receives tool_start, calculator_completed /
# tool_complete, and the submit payload used to upsert the HubSpot contact
# and trigger the report email + SMS + nurture. Never commit a real URL.
COMPLIANCE_CHECK_WEBHOOK_URL=

# Secret used to HMAC-sign the report token embedded in report URLs
# (app/report/[token]). Required in production. Any long random string in
# local dev. Never commit a real secret.
REPORT_TOKEN_SECRET=dev-only-insecure-secret-change-me

# Public base URL used to build the shareable report link sent by email/SMS.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature flag for the Meta Pixel + CAPI hooks. Defaults OFF in code. Set to
# "true" and set NEXT_PUBLIC_META_PIXEL_ID below to enable. Do not enable
# before the Hard Gates in CLAUDE.md clear.
NEXT_PUBLIC_ENABLE_PIXEL=false
NEXT_PUBLIC_META_PIXEL_ID=

# HubSpot scheduler embed, same link everywhere in the funnel.
NEXT_PUBLIC_BOOKING_URL=https://meetings.hubspot.com/bethechangehr/discoverycall
